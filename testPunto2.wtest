import empleados.*

test "Qué hacen los empleados con lo que cobran" {
	
  empleado2.venderEmpanadas(500)
  dueño.nuevoSueldoDeGalvan(20000)
  empleado2.venderEmpanadas(300)
  dueño.pagarSueldo(empleado2)
  dueño.pagarSueldo(empleado1)
  
  empleado2.vender(100)
  dueño.pagarSueldo(empleado2)
  assert.equals(13500, empleado2.totalCobrado())
  
 	
}